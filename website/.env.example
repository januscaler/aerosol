# Used at build time (local: copy to `.env`; Docker: pass as build-args).
VITE_GITHUB_REPO=januscaler/aerosol
VITE_SITE_URL=https://aerosol.januscaler.com
VITE_APP_VERSION=0.1.0
# If empty, download links use v{VITE_APP_VERSION}
VITE_RELEASE_TAG=v0.1.0
# Optional exact release asset filenames:
# VITE_ASSET_MAC_DMG=Aerosol_0.1.0_universal.dmg
# VITE_ASSET_WIN=Aerosol_0.1.0_x64_en-US.msi
# VITE_ASSET_LINUX_APPIMAGE=aerosol_0.1.0_amd64.AppImage
